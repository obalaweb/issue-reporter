{
    "name": "codprez/issue-reporter",
    "description": "Zero-repetition error ingestion SDK for Codprez Cloud",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ivan",
            "email": "ivan@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Codprez\\IssueReporter\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Codprez\\IssueReporter\\IssueReporterServiceProvider"
            ],
            "aliases": {
                "Issue": "Codprez\\IssueReporter\\Facades\\Issue"
            }
        }
    }
}